## Backend environment variables (example)
##
## Copy to `.env` for local development, or set these in your hosting provider
## (Render, etc.). Do NOT commit real secrets.

# Frontend URL allowed by CORS
FRONTEND_URL=http://localhost:5173

# Optional comma-separated extra allowed origins for CORS
# Example: https://er-psols.vercel.app,https://preview-app.vercel.app
# CORS_ALLOW_ORIGINS=

# JWT signing secret (change in production)
SECRET_KEY=change-this-secret-in-production

# SMTP email delivery.
# Gmail typically needs an App Password (2FA enabled), not your normal password.
SENDER_EMAIL=you@gmail.com
SENDER_EMAIL_PASSWORD=your_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_STARTTLS=false

# If your SMTP provider supports an alternate port such as 2525, set it here.
# Example:
# SMTP_HOST=smtp.provider.com
# SMTP_PORT=2525
# SMTP_USE_SSL=false
# SMTP_STARTTLS=true

# Optional: allow insecure TLS if your host blocks CA verification (not recommended)
# SMTP_ALLOW_INSECURE_TLS=false

# Optional dev-only fallback: if SMTP fails, return 200 with a dev OTP (use only locally)
# DEV_OTP_FALLBACK=false
# EXPOSE_DEV_OTP=false
